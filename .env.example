# Supabase Configuration
VITE_SUPABASE_URL=your-supabase-url
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
VITE_SUPABASE_PROJECT_ID=your-project-id
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# LLM Provider Configuration
LLM_PROVIDER=LOVABLE
OPENROUTER_API_KEY=your-openrouter-key-if-needed

# Yandex SpeechKit Configuration
YANDEX_CLOUD_FOLDER_ID=your-folder-id
YANDEX_SPEECHKIT_API_KEY=your-speechkit-api-key

# Polza.ai Embeddings Configuration
POLZA_API_KEY=your-polza-api-key
POLZA_EMBED_URL=https://api.polza.ai/api/v1/embeddings
POLZA_EMBED_MODEL=text-embedding-3-large
EMBED_DIM=3072
JIVA_EMBED_PROVIDER=polza

# Jīva Pricing Configuration (RUB)
JIVA_PREMIUM_PRICE_RUB=890
JIVA_EXTRA_DIALOG_PRICE_RUB=59
RESEARCHER_FREE_DAILY_MSG=3
RESEARCHER_PREMIUM_DAILY_MSG=20

# Feature Flags
FEATURE_JIVA=true
FEATURE_MICRO_PURCHASES=true
FEATURE_AB_TEST_PRICING=true
