# Pricing Configuration (editable without code changes)
VITE_PRICE_PREMIUM_RUB=1190
VITE_PRICE_EXTRA_JIVA_RUB=79
VITE_PRICE_PLUS_RUB=699

# Feature Flags
VITE_ENABLE_PLUS=false
VITE_ENABLE_TRIAL_7D=false

# Billing Provider
VITE_BILLING_PROVIDER=yookassa

# Cost Model
VITE_USD_RUB=82
VITE_ELEVEN_RUB=120
VITE_ELEVEN_PER_1K_CHARS_USD=0.30

# YooKassa (primary)
VITE_YOOKASSA_SHOP_ID=
VITE_YOOKASSA_RETURN_URL=https://yourdomain.com/billing/return

# Stripe (fallback)
VITE_STRIPE_PUBLISHABLE_KEY=

# =================================================================
# Polza AI Embeddings Configuration
# =================================================================

# Polza API Key (set in Supabase Secrets dashboard)
POLZA_API_KEY=__SET_IN_SUPABASE_SECRETS__
POLZA_EMBED_URL=https://api.polza.ai/api/v1/embeddings
POLZA_EMBED_MODEL=text-embedding-3-large

# Jiva Embeddings Settings
JIVA_EMBED_PROVIDER=polza              # Primary: polza | lovable
JIVA_EMBED_FALLBACK=lovable            # Fallback provider
JIVA_EMBED_MODE=auto                   # Processing mode: auto | manual | off
JIVA_EMBED_DIM=3072                    # Vector dimensions (3072 for text-embedding-3-large)
JIVA_EMBED_BATCH=32                    # Batch size for API calls
JIVA_EMBED_CONCURRENCY=2               # Parallel batches
JIVA_EMBED_MIN_CHARS=80                # Minimum text length to embed
JIVA_EMBED_MAX_TOKENS=800              # Max tokens per chunk
JIVA_EMBED_DAILY_BUDGET_RUB=120        # Daily spending cap in RUB

# Public env for client-side budget display
NEXT_PUBLIC_JIVA_EMBED_DAILY_BUDGET_RUB=120
